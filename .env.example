# Copy this file to .env for local runs. Keep .env out of Git.
CANVAS_BASE_URL=https://lu.instructure.com
CANVAS_TOKEN=
CANVAS_ACCOUNT_ID=1
CANVAS_ALLOW_USER_COURSE_DISCOVERY=false

# Required for backup runs so retries resume in the same directory.
# Real backup runs should use a stable run folder under E:\CanvasBackup and reuse it for retries.
# List-only and check-config runs can leave this blank and use E:\CanvasBackup\canvas-<timestamp>.
CANVAS_OUTPUT_DIR=
CANVAS_BACKUP_MODE=both
CANVAS_COURSE_STATES=created,claimed,available,completed
CANVAS_CREATED_AFTER=2025-04-01
# Exclusion terms match only at field edges: absolute end, or beginning followed by non-a-z.
CANVAS_EXCLUDE_COURSE_NAME_TERMS=test,sandlåda,sandlada,sandbox,mall,template,demo
CANVAS_EXCLUDE_SUBACCOUNT_NAME_TERMS=sandbox
# Keep this true for broad runs so courses with Canvas-reported total_students=0 are excluded.
CANVAS_EXCLUDE_COURSES_WITHOUT_STUDENTS=true
CANVAS_COURSE_IDS=
CANVAS_COURSE_IDS_FILE=
CANVAS_MAX_COURSES=
# Approved emergency storage guardrail. Canvas course files larger than this many MB are not downloaded.
# File metadata, size summaries, and skip records are still saved for later follow-up.
CANVAS_MAX_FILE_SIZE_MB=300
CANVAS_CONCURRENCY=1
CANVAS_FILE_CONCURRENCY=2
CANVAS_MAX_RETRIES=5
CANVAS_STAFF_INCLUDE_DELETED=false
CANVAS_EXPORT_TYPES=common_cartridge
CANVAS_EXPORT_POLL_SECONDS=15
CANVAS_EXPORT_TIMEOUT_MINUTES=90
CANVAS_WAIT_EXPORTS=true
CANVAS_SKIP_FILE_DOWNLOADS=false
